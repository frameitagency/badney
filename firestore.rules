rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Auth Core Reusable Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User profile schema validation helper
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
          && data.keys().size() == 4
          && data.uid == request.auth.uid
          && data.email is string && data.email.size() <= 128
          && data.displayName is string && data.displayName.size() <= 128
          && data.createdAt == request.time;
    }

    // users collection match
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
    }

    // 2. Order schema validation helper
    function isValidOrder(data) {
      return data.keys().hasAll([
        'id', 'userId', 'customerName', 'phone', 'address', 'city', 
        'postalCode', 'province', 'items', 'subtotal', 'shippingCost', 
        'finalTotal', 'createdAt', 'status'
      ])
          && data.keys().size() <= 15
          && data.id is string && data.id.size() <= 128
          && data.userId == request.auth.uid
          && data.customerName is string && data.customerName.size() <= 256
          && data.phone is string && data.phone.size() <= 64
          && data.address is string && data.address.size() <= 512
          && data.city is string && data.city.size() <= 128
          && data.postalCode is string && data.postalCode.size() <= 32
          && data.province is string && data.province.size() <= 64
          && data.items is list && data.items.size() <= 20
          && data.subtotal is number
          && data.shippingCost is number
          && data.finalTotal is number
          && data.createdAt == request.time
          && data.status in ['PENDING', 'COMPLETED'];
    }

    // orders collection match
    match /orders/{orderId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(orderId) && isValidOrder(incoming());
    }
  }
}
